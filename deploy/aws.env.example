# Copy these values into your AWS secret/config system per environment.
# Do not commit real values.

ENVIRONMENT=staging
DEPLOY_VERSION=TODO_GIT_SHA_OR_RELEASE_VERSION
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=false

# TODO(secret): Generate a unique secret per environment and store it in AWS
# Secrets Manager or SSM Parameter Store.
DJANGO_SECRET_KEY=TODO_GENERATE_ENVIRONMENT_SECRET
INTEGRATION_CREDENTIALS_KEY=TODO_GENERATE_DISTINCT_INTEGRATION_CREDENTIALS_KEY

# TODO(domain): Replace with the API domain or load balancer hostname.
DJANGO_ALLOWED_HOSTS=api.staging.example.com

# TODO(domain): Replace with the public frontend origin for this environment.
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.staging.example.com
CORS_ALLOWED_ORIGINS=https://app.staging.example.com
FRONTEND_BASE_URL=https://app.staging.example.com
AUTH_REFRESH_COOKIE_NAME=saas_core_refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth/
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAMESITE=Lax
EMAIL_VERIFICATION_MAX_AGE=86400
ORGANIZATION_INVITATION_MAX_AGE=604800
# TODO(google-login): Add the public web OAuth Client ID only if this product
# enables Google sign-in. The Client Secret is not required by the ID-token flow.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_NONCE_COOKIE_NAME=saas_core_google_oauth_nonce
GOOGLE_OAUTH_NONCE_MAX_AGE=600
# TODO(network): Set true only after direct backend access is blocked and the
# load balancer/proxy strips incoming X-Forwarded-For before appending its own.
AUDIT_TRUST_X_FORWARDED_FOR=false
BILLING_ALLOWED_REDIRECT_HOSTS=app.staging.example.com
MAX_JSON_PAYLOAD_BYTES=65536

# TODO(aws-rds): Replace with the RDS PostgreSQL connection URL from Secrets
# Manager. Use a user with least-privilege app access.
DATABASE_URL=postgres://TODO_USER:TODO_PASSWORD@TODO_RDS_ENDPOINT:5432/TODO_DB

# TODO(aws-elasticache): Replace with ElastiCache Redis endpoints.
REDIS_URL=redis://TODO_REDIS_ENDPOINT:6379/0
CELERY_BROKER_URL=redis://TODO_REDIS_ENDPOINT:6379/0
CELERY_RESULT_BACKEND=redis://TODO_REDIS_ENDPOINT:6379/1
HEALTHCHECK_REQUIRE_REDIS=true
HEALTHCHECK_REDIS_URL=redis://TODO_REDIS_ENDPOINT:6379/0

AWS_REGION=eu-central-1

# TODO(aws-s3): Create one bucket per environment/product where reports or
# exports need durable object storage.
AWS_STORAGE_BUCKET_NAME=TODO_S3_BUCKET
AWS_S3_ENDPOINT_URL=

# TODO(stripe): Create Stripe test keys first. Add live keys only after the
# product billing flow is verified end to end.
STRIPE_SECRET_KEY=TODO_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=TODO_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_FREE=TODO_STRIPE_PRICE_FREE
STRIPE_PRICE_STARTER=TODO_STRIPE_PRICE_STARTER
STRIPE_PRICE_PRO=TODO_STRIPE_PRICE_PRO
STRIPE_PRICE_AGENCY=TODO_STRIPE_PRICE_AGENCY

# TODO(ai): Add provider keys only for products that need real provider calls.
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=TODO_DEFAULT_MODEL
OPENAI_API_KEY=TODO_OPENAI_API_KEY
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# TODO(email): Keep console disabled in production. Use SES, Resend, Postmark,
# or another approved transactional provider.
EMAIL_PROVIDER=ses
DEFAULT_FROM_EMAIL=no-reply@staging.example.com
AWS_SES_REGION=eu-central-1

# TODO(compliance): Set per SaaS, contract, and jurisdiction before launch.
DATA_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=2555

# TODO(observability): Add Sentry DSN per environment before production launch.
# TODO(observability): Use JSON logs in AWS so CloudWatch queries stay reliable.
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=TODO_SENTRY_DSN
SENTRY_TRACES_SAMPLE_RATE=0.05
