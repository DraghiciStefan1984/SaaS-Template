{
  "name": "saas-core-template-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "backend:check": "node scripts/backend-command.mjs manage.py check",
    "backend:migrate": "node scripts/backend-command.mjs manage.py migrate",
    "backend:migrations:check": "node scripts/backend-command.mjs manage.py makemigrations --check --dry-run",
    "backend:test": "node scripts/backend-command.mjs -m pytest",
    "backend:lint": "node scripts/backend-command.mjs -m ruff check .",
    "backend:seed": "node scripts/backend-command.mjs manage.py seed_dev_data",
    "backend:demo-check": "node scripts/backend-command.mjs manage.py check_demo_ready",
    "demo:seed": "node scripts/backend-command.mjs manage.py seed_dev_data",
    "demo:check": "node scripts/backend-command.mjs manage.py check_demo_ready",
    "demo:prepare": "node scripts/backend-command.mjs manage.py check_demo_ready --migrate --seed",
    "docker:config": "node scripts/docker-compose.mjs config",
    "docker:build": "node scripts/docker-compose.mjs build",
    "docker:up": "node scripts/docker-compose.mjs up",
    "docker:down": "node scripts/docker-compose.mjs down",
    "docker:ps": "node scripts/docker-compose.mjs ps",
    "docker:logs": "node scripts/docker-compose.mjs logs",
    "docker:demo:prepare": "node scripts/docker-compose.mjs run --rm backend python manage.py check_demo_ready --migrate --seed",
    "deploy:check": "node scripts/backend-command.mjs manage.py check_deploy_ready",
    "deploy:check:production": "node scripts/backend-command.mjs manage.py check_deploy_ready --environment production",
    "deploy:check:full": "node scripts/backend-command.mjs manage.py check_deploy_ready --environment production --require-billing --require-ai --require-email --require-storage --require-observability",
    "security:backend:deploy-check": "node scripts/backend-command.mjs manage.py check --deploy",
    "security:frontend:audit": "npm --prefix frontend audit --audit-level=moderate",
    "product:scaffold": "node scripts/scaffold-product.mjs",
    "product:scaffold:dry-run": "node scripts/scaffold-product.mjs --slug sample-product --name \"Sample Product\" --dry-run",
    "product:check": "node scripts/check-productization.mjs",
    "release:check": "node scripts/release-check.mjs",
    "frontend:dev": "npm --prefix frontend run dev -- --host 127.0.0.1 --port 5173",
    "frontend:lint": "npm --prefix frontend run lint",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "frontend:test": "npm --prefix frontend run test",
    "frontend:build": "npm --prefix frontend run build",
    "check": "npm run backend:lint && npm run backend:check && npm run backend:migrations:check && npm run backend:test && npm run frontend:lint && npm run frontend:typecheck && npm run frontend:test && npm run frontend:build"
  }
}
