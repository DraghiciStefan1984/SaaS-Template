# Django
ENVIRONMENT=local
DEPLOY_VERSION=local
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-local-only-minimum-32-bytes
INTEGRATION_CREDENTIALS_KEY=change-me-local-integration-credentials-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_REFRESH_COOKIE_NAME=saas_core_refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth/
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUDIT_TRUST_X_FORWARDED_FOR=false
# TODO(deployment): In staging/production, replace localhost with the real API
# domain, frontend domain, and load balancer health-check hostnames.
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0

# Database
# TODO(external-service): For AWS, replace this with an RDS PostgreSQL URL from
# Secrets Manager or ECS task secrets.
DATABASE_URL=postgres://saas_core:change-me-local@postgres:5432/saas_core

# Redis / Celery
# TODO(external-service): For AWS, replace local Redis with ElastiCache Redis.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
HEALTHCHECK_REQUIRE_REDIS=true
HEALTHCHECK_REDIS_URL=redis://redis:6379/0

# Frontend
FRONTEND_BASE_URL=http://localhost:5173
BILLING_ALLOWED_REDIRECT_HOSTS=localhost:5173,127.0.0.1:5173
MAX_JSON_PAYLOAD_BYTES=65536

# Stripe
# TODO(external-account): Create a Stripe account before implementing live billing.
# Use Stripe test mode first. Never put live keys in local example files.
# Required later:
# - STRIPE_SECRET_KEY: server-side test/live secret key.
# - STRIPE_WEBHOOK_SECRET: webhook signing secret for the exact environment.
# - STRIPE_PRICE_*: Stripe Price IDs for subscription plans.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# AI providers
# TODO(external-account): Create an OpenAI project/API key before enabling real AI calls.
# Anthropic and Gemini keys stay empty until a product explicitly needs fallback providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=

# AWS / storage
# TODO(external-account): Create an AWS account before production deployment.
# Use managed AWS services in production: RDS, ElastiCache, S3, ECS Fargate, Secrets Manager.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# Email
# TODO(external-account): Keep console email locally. Connect SES or Resend only when
# we implement real outbound email/invite/report delivery.
EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=no-reply@example.com
AWS_SES_REGION=eu-central-1

# Privacy / retention
# TODO(compliance): Tune per SaaS, customer contracts, and applicable law before
# production launch. Deletion requests are intentionally review-based by default.
DATA_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=2555

# Observability
# TODO(observability): Use LOG_FORMAT=json in containers/staging/production so
# CloudWatch or any log collector can parse records consistently.
LOG_LEVEL=INFO
LOG_FORMAT=plain
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
