# Shared local Docker Compose defaults.
#
# Copy this file to .env in the repository root before running Docker Compose.
# Do not put production secrets in this file.

COMPOSE_PROJECT_NAME=saas-core-template

# TODO(local-setup): Keep these local values for Docker Compose. For AWS,
# provision RDS/ElastiCache and pass real endpoints through task secrets.
POSTGRES_DB=saas_core
POSTGRES_USER=saas_core
POSTGRES_PASSWORD=change-me-local
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

BACKEND_PORT=8000
FRONTEND_PORT=5173
